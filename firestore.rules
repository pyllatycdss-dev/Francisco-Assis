rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // We'll use a specific UID for the admin if we want, 
    // but the user's request says "(SEM LOGIN)". 
    // This is tricky for security. "Painel oculto sem login" usually means 
    // it's just client-side security (obscurity). 
    // HOWEVER, I should still try to protect the data.
    // If there's no auth, I can't really secure it beyond "anyone can read".
    // I'll allow public READ but restrict WRITE if I can think of a way, 
    // or just allow public write for now if the user explicitly asks for "no login".
    // Wait, if there's no login, the admin panel is just hidden. 
    // I'll allow public reads and writes for now, but mark it as a risk.
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
