{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A women's clothing item available for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string" } },
        "isNew": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "isPromotion": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase record containing customer and product details.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "items": { "type": "array" },
        "totalValue": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of store products."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders placed by customers."
    }
  }
}
